{
  "name": "packwise",
  "version": "1.2.1",
  "description": "Open-source, offline-first packing list and gear organizer with optional cloud sync.",
  "private": true,
  "author": "Alex Mengoli (MxApps)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "pnpm --filter @packwise/client start",
    "build": "pnpm --filter @packwise/shared build && pnpm --filter @packwise/client build",
    "build:pages": "pnpm --filter @packwise/shared build && pnpm --filter @packwise/client build --base-href /Packwise/",
    "lint": "pnpm --filter @packwise/client lint",
    "build:shared": "pnpm --filter @packwise/shared build",
    "android:icons": "powershell -ExecutionPolicy Bypass -File ./scripts/android-generate-icons.ps1",
    "android:apk:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/android-build-debug.ps1",
    "android:apk:debug:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/android-build-debug.ps1 -AcceptAndroidSdkLicenses"
  }
}
