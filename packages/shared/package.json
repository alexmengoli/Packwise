{
  "name": "@packwise/shared",
  "version": "1.3.1",
  "description": "Shared TypeScript models and domain utilities for Packwise.",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "typescript": "~5.9.0"
  }
}